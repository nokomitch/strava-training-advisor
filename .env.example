# Strava API credentials
# Register at: https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to: localhost
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# Tokens are set automatically by scripts/setup_oauth.py
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_TOKEN_EXPIRES_AT=0

# Anthropic API key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Uphill Athlete training zones (heart rate in bpm)
# Use the Heart Rate Drift Test to find your AeT:
# https://uphillathlete.com/aerobic-training/heart-rate-drift-test/
ATHLETE_AET_HR=150
ATHLETE_ANT_HR=170

# Discord Webhook URL for notifications
# Create one in Discord: Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here
